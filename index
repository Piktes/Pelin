<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<title>Okul Sınıflandırması</title>
<style>
  :root{
    --ink:#1f2a44; --line:#9aa6bd; --root:#8e1d3a; --accent:#8e1d3a;
    --border:#c3ccdc; --shadow:rgba(31,42,68,.08);
  }
  *{box-sizing:border-box;margin:0;padding:0;}
  body{background:#fff;font-family:"Saira","Segoe UI",Roboto,Arial,sans-serif;color:var(--ink);}
  .wrap{padding:24px 20px;}
  h1{font-size:18px;font-weight:600;margin-bottom:8px;}
  h1 span{color:var(--accent);}

  /* canvas holds absolutely-positioned boxes + an SVG layer behind them */
  .canvas{position:relative;width:1300px;height:660px;}
  svg.links{position:absolute;inset:0;width:100%;height:100%;z-index:1;overflow:visible;}
  svg.links path{
    fill:none;stroke:var(--line);stroke-width:2;
    stroke-dasharray:6 6;animation:flow 1.1s linear infinite;
  }
  svg.links polygon{fill:var(--line);}
  @keyframes flow{to{stroke-dashoffset:-12;}}

  .node{
    position:absolute;z-index:2;background:#fff;border:1.5px solid var(--border);
    border-radius:8px;display:flex;align-items:center;justify-content:center;
    text-align:center;font-size:13px;line-height:1.2;padding:6px 10px;
    box-shadow:0 1px 3px var(--shadow);transition:border-color .2s,box-shadow .2s;
  }
  .node:hover{border-color:var(--accent);box-shadow:0 3px 10px rgba(142,29,58,.18);}
  .root{
    background:var(--root);color:#fff;border-color:var(--root);
    writing-mode:vertical-rl;transform:rotate(180deg);
    font-size:22px;font-weight:700;letter-spacing:3px;
  }
  .l1{font-weight:600;}
  .legend{margin-top:14px;font-size:11px;color:#7a849b;}

  /* widths */
  .w150{width:150px;} .w185{width:185px;} .w205{width:205px;}
</style>
</head>
<body>
<div class="wrap">
  <h1>Şekil 3. <span>Okul Sınıflandırması</span></h1>

  <div class="canvas">
    <!-- ===== connector layer (drawn first, sits behind) ===== -->
    <svg class="links" viewBox="0 0 1300 660" preserveAspectRatio="none">
      <!-- root(95,305) -> L1 (x=300) : 3 children at y=145,305,465 -->
      <path d="M95,305 C200,305 200,145 300,145"/><polygon points="294,141 300,145 294,149"/>
      <path d="M95,305 C200,305 200,305 300,305"/><polygon points="294,301 300,305 294,309"/>
      <path d="M95,305 C200,305 200,465 300,465"/><polygon points="294,461 300,465 294,469"/>

      <!-- L1 'Eğitim Kademesine' (right x=560,y=145) -> L2 (x=600) Okul Öncesi/İlköğretim/Ortaöğretim y=60,140,220 -->
      <path d="M560,145 C580,145 580,60 600,60"/><polygon points="594,56 600,60 594,64"/>
      <path d="M560,145 C580,145 580,140 600,140"/><polygon points="594,136 600,140 594,144"/>
      <path d="M560,145 C580,145 580,220 600,220"/><polygon points="594,216 600,220 594,224"/>
      <!-- L1 'Resmî-Özel' (x=560,y=305) -> Resmî Okullar/Özel Okullar y=300,380 -->
      <path d="M560,305 C580,305 580,300 600,300"/><polygon points="594,296 600,300 594,304"/>
      <path d="M560,305 C580,305 580,380 600,380"/><polygon points="594,376 600,380 594,384"/>
      <!-- L1 'Yurt Dışındaki' (x=560,y=465) -> Türk Okulları y=460 -->
      <path d="M560,465 C580,465 580,460 600,460"/><polygon points="594,456 600,460 594,464"/>

      <!-- L2 Okul Öncesi (x=790,y=60) -> L3 Anaokulu/Ana Sınıfı/Uygulama y=30,90,150 -->
      <path d="M790,60 C810,60 810,30 830,30"/><polygon points="824,26 830,30 824,34"/>
      <path d="M790,60 C810,60 810,90 830,90"/><polygon points="824,86 830,90 824,94"/>
      <path d="M790,60 C810,60 810,150 830,150"/><polygon points="824,146 830,150 824,154"/>
      <!-- L2 İlköğretim (x=790,y=140) -> İlkokul(210)/Ortaokul(270) -->
      <path d="M790,140 C810,140 810,210 830,210"/><polygon points="824,206 830,210 824,214"/>
      <path d="M790,140 C810,140 810,270 830,270"/><polygon points="824,266 830,270 824,274"/>
      <!-- L2 Ortaöğretim (x=790,y=220) -> Genel(330)/Mesleki(390)/İmam Hatip(450) -->
      <path d="M790,220 C810,220 810,330 830,330"/><polygon points="824,326 830,330 824,334"/>
      <path d="M790,220 C810,220 810,390 830,390"/><polygon points="824,386 830,390 824,394"/>
      <path d="M790,220 C810,220 810,450 830,450"/><polygon points="824,446 830,450 824,454"/>
      <!-- L2 Özel Okullar (x=790,y=380) -> Özel Türk(510)/Yabancı(560)/Azınlık(610)/Milletlerarası(650) -->
      <path d="M790,380 C810,380 810,510 830,510"/><polygon points="824,506 830,510 824,514"/>
      <path d="M790,380 C810,380 810,560 830,560"/><polygon points="824,556 830,560 824,564"/>
      <path d="M790,380 C810,380 810,610 830,610"/><polygon points="824,606 830,610 824,614"/>
      <path d="M790,380 C810,380 810,650 830,650"/><polygon points="824,646 830,650 824,654"/>

      <!-- L3 Ortaokul (x=1035,y=270) -> L4 (x=1075) y=210,270,330 -->
      <path d="M1035,270 C1055,270 1055,210 1075,210"/><polygon points="1069,206 1075,210 1069,214"/>
      <path d="M1035,270 C1055,270 1055,270 1075,270"/><polygon points="1069,266 1075,270 1069,274"/>
      <path d="M1035,270 C1055,270 1055,330 1075,330"/><polygon points="1069,326 1075,330 1069,334"/>
    </svg>

    <!-- ===== ROOT ===== -->
    <div class="node root" style="left:20px;top:265px;width:55px;height:80px;">OKUL</div>

    <!-- ===== LEVEL 1 (x 300–560, w260) ===== -->
    <div class="node l1" style="left:300px;top:125px;width:260px;height:40px;">Eğitim Kademesine Göre Okul</div>
    <div class="node l1" style="left:300px;top:285px;width:260px;height:40px;">Resmî-Özel Ayrımında Okul</div>
    <div class="node l1" style="left:300px;top:445px;width:260px;height:40px;">Yurt Dışındaki Türk Okulları</div>

    <!-- ===== LEVEL 2 (x 600–790, w190) ===== -->
    <div class="node" style="left:600px;top:42px;width:190px;height:36px;">Okul Öncesi</div>
    <div class="node" style="left:600px;top:122px;width:190px;height:36px;">İlköğretim</div>
    <div class="node" style="left:600px;top:202px;width:190px;height:36px;">Ortaöğretim</div>
    <div class="node" style="left:600px;top:282px;width:190px;height:36px;">Resmî Okullar</div>
    <div class="node" style="left:600px;top:362px;width:190px;height:36px;">Özel Okullar</div>
    <div class="node" style="left:600px;top:442px;width:190px;height:36px;">Türk Okulları</div>

    <!-- ===== LEVEL 3 (x 830–1035, w205) ===== -->
    <div class="node" style="left:830px;top:12px;width:205px;height:36px;">Anaokulu</div>
    <div class="node" style="left:830px;top:72px;width:205px;height:36px;">Ana Sınıfı</div>
    <div class="node" style="left:830px;top:132px;width:205px;height:36px;">Uygulama Sınıfı</div>
    <div class="node" style="left:830px;top:192px;width:205px;height:36px;">İlkokul</div>
    <div class="node" style="left:830px;top:252px;width:205px;height:36px;">Ortaokul</div>
    <div class="node" style="left:830px;top:312px;width:205px;height:36px;">Genel Ortaöğretim</div>
    <div class="node" style="left:830px;top:372px;width:205px;height:36px;">Mesleki ve Teknik Ortaöğretim</div>
    <div class="node" style="left:830px;top:432px;width:205px;height:36px;">İmam Hatip Liseleri</div>
    <div class="node" style="left:830px;top:492px;width:205px;height:36px;">Özel Türk Okulları</div>
    <div class="node" style="left:830px;top:542px;width:205px;height:36px;">Yabancı Okullar</div>
    <div class="node" style="left:830px;top:592px;width:205px;height:36px;">Azınlık Okulları</div>
    <div class="node" style="left:830px;top:632px;width:205px;height:36px;">Milletlerarası Okullar</div>

    <!-- ===== LEVEL 4 (x 1075, w205) ===== -->
    <div class="node" style="left:1075px;top:192px;width:205px;height:36px;">Genel Eğitim Veren Ortaokullar</div>
    <div class="node" style="left:1075px;top:252px;width:205px;height:36px;">Meslek Ortaokulları</div>
    <div class="node" style="left:1075px;top:312px;width:205px;height:36px;">İmam Hatip Ortaokulları</div>
  </div>


</div>
</body>
</html>
